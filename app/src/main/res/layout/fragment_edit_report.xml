<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lf_background">

    <!-- Form edit -->
    <ScrollView
        android:id="@+id/formContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="invisible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="20dp"
            android:paddingEnd="24dp"
            android:paddingBottom="40dp">

            <!-- Kembali -->
            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:paddingEnd="16dp"
                android:text="@string/back"
                android:textColor="@color/lf_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Judul -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/edit_report_title"
                android:textColor="@color/lf_text_primary"
                android:textSize="27sp"
                android:textStyle="bold" />

            <!-- Penjelasan -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/edit_report_description"
                android:textColor="@color/lf_text_secondary"
                android:textSize="15sp" />

            <!-- Jenis laporan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="@string/report_type_label"
                android:textColor="@color/lf_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgReportType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbLost"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/lost_item"
                    android:textColor="@color/lf_text_primary" />

                <RadioButton
                    android:id="@+id/rbFound"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/found_item"
                    android:textColor="@color/lf_text_primary" />

            </RadioGroup>

            <!-- Nama barang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/item_name_label"
                android:textColor="@color/lf_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etItemName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:hint="@string/item_name_hint"
                android:inputType="textCapWords"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <!-- Kategori -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/category_form_label"
                android:textColor="@color/lf_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spCategory"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:entries="@array/item_categories"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <!-- Lokasi lengkap -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/full_location_label"
                android:textColor="@color/lf_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="top"
                android:hint="@string/full_location_hint"
                android:inputType="textCapSentences|textMultiLine"
                android:minHeight="90dp"
                android:padding="16dp" />

            <!-- Tanggal -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/event_date_form_label"
                android:textColor="@color/lf_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etEventDate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:hint="@string/event_date_hint"
                android:inputType="none"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <!-- Deskripsi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/item_description_form_label"
                android:textColor="@color/lf_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="top"
                android:hint="@string/item_description_hint"
                android:inputType="textCapSentences|textMultiLine"
                android:minHeight="120dp"
                android:padding="16dp" />

            <!-- Nomor WhatsApp -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/contact_form_label"
                android:textColor="@color/lf_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etContact"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:hint="@string/contact_form_hint"
                android:inputType="phone"
                android:maxLength="15"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <!-- Gambar -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/photo_form_label"
                android:textColor="@color/lf_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivImagePreview"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="10dp"
                android:background="@color/lf_border"
                android:contentDescription="@string/image_item_description"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery" />

            <TextView
                android:id="@+id/tvImageStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/keeping_old_image"
                android:textColor="@color/lf_text_secondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnChooseImage"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/lf_secondary"
                android:text="@string/choose_new_image"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <!-- Tombol update -->
            <Button
                android:id="@+id/btnUpdateReport"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="30dp"
                android:backgroundTint="@color/lf_primary"
                android:text="@string/update_report"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center" />

</FrameLayout>