<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/lf_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/lf_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- Foto barang -->
        <ImageView
            android:id="@+id/ivItem"
            android:layout_width="100dp"
            android:layout_height="120dp"
            android:background="@color/lf_border"
            android:contentDescription="Foto barang"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery" />

        <!-- Informasi barang -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Jenis laporan -->
            <TextView
                android:id="@+id/tvReportType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_lost"
                android:text="HILANG"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Nama barang -->
            <TextView
                android:id="@+id/tvItemTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Dompet Kulit Hitam"
                android:textColor="@color/lf_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <!-- Kategori -->
            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Kategori: Dompet"
                android:textColor="@color/lf_text_secondary"
                android:textSize="13sp" />

            <!-- Lokasi -->
            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Lokasi: Cakranegara"
                android:textColor="@color/lf_text_secondary"
                android:textSize="13sp" />

            <!-- Tanggal -->
            <TextView
                android:id="@+id/tvDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Tanggal: 22 Juni 2026"
                android:textColor="@color/lf_text_secondary"
                android:textSize="13sp" />

            <!-- Status -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Belum selesai"
                android:textColor="@color/lf_status_open"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnBookmark"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/lf_primary"
                android:text="@string/save_bookmark"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>